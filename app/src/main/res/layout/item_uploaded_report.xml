<?xml version="1.0" encoding="utf-8"?>
<!--
    Single row in the "Uploaded reports" list.
    Shows:
      - A document icon on the left
      - File name (bold) and file size below it
      - A green "Analysed" badge on the right
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_report_item"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Document icon on the left -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_document"
        android:contentDescription="File icon"
        android:alpha="0.6" />

    <!-- File name + size (takes up remaining space) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- e.g. "Blood_Report_Nov24.pdf" -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="filename.pdf"
            android:textColor="#222222"
            android:textStyle="bold"
            android:textSize="14sp" />

        <!-- e.g. "2.4 MB" -->
        <TextView
            android:id="@+id/tvFileSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 MB"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- "Analysed" status badge on the right -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Analysed"
        android:textColor="#1B8B5A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_badge_green"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

</LinearLayout>