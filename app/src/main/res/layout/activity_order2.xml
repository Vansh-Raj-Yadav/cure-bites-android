<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Top Green Header -->
    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="#0B8F5A"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/baseline_arrow_back_24"
        app:tint="#FFFFFF"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/app_logo"
        app:layout_constraintTop_toTopOf="@id/topHeader"
        app:layout_constraintBottom_toBottomOf="@id/topHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Main White Section -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/topHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order on the way!"
            android:textStyle="bold"
            android:textSize="30sp"
            android:textColor="#000000"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arriving in 12–15 minutes"
            android:textSize="18sp"
            android:layout_marginBottom="30dp"
            android:textColor="@color/grey_text"
            android:layout_gravity="center_horizontal"/>

        <!-- Timeline Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:orientation="horizontal">

            <!-- Left Timeline -->
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Circle -->
                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/green_circle"/>

                <!-- Line -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="60dp"
                    android:background="#0B8F5A"/>

                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/green_circle"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="60dp"
                    android:background="#0B8F5A"/>

                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/green_circle"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="60dp"
                    android:background="#BDBDBD"/>

                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/gray_circle"/>

            </LinearLayout>

            <!-- Status Text -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:text="Order Confirmed ✔"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:backgroundTint="#000000"
                    android:textSize="22sp"
                    android:textColor="#000000"/>


                <TextView
                    android:text="11:30 AM"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/grey_text"/>

                <TextView
                    android:layout_marginTop="35dp"
                    android:text="Meal Prepared ✔"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:backgroundTint="@color/black"
                    android:textSize="22sp"
                    android:textColor="#000000"/>

                <TextView
                    android:text="12:10 PM"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:backgroundTint="@color/black"
                    android:textSize="16sp"
                    android:textColor="@color/grey_text"/>

                <TextView
                    android:text="Out for Delivery"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginTop="35dp"
                    android:backgroundTint="@color/black"
                    android:textSize="22sp"
                    android:textColor="#000000"/>

                <TextView
                    android:text="Now"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:backgroundTint="@color/black"
                    android:textSize="16sp"
                    android:textColor="@color/grey_text"/>

                <TextView
                    android:text="Delivered"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textColor="@color/grey_text"
                    android:layout_marginTop="28dp"/>

                <TextView
                    android:text="~12:40 PM"
                    android:textSize="16sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textColor="@color/grey_text"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Delivery Partner Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:outlineAmbientShadowColor="@color/black"
            android:padding="12dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/profile_icon"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:text="Ram Kumar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textStyle="bold"
                    android:textSize="20sp"/>

                <TextView
                    android:text="Delivery Partner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textSize="16sp"/>

                <TextView
                    android:text="4.9⭐"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textSize="16sp"/>

            </LinearLayout>

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_call"
                app:tint="#000000" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="16dp"
                app:tint="#000000"
                android:src="@android:drawable/ic_dialog_email"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>