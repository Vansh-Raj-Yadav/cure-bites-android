<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- MAIN SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_navigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- DEEP GREEN HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#008B5E"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="32dp">

                <!-- Back Arrow -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#FFFFFF"
                    android:layout_marginBottom="24dp" />

                <!-- Profile Info Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- White Square Avatar Wrapper -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:padding="4dp"
                            app:tint="#008B5E"
                            android:src="@drawable/ic_profile_avatar" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priya Sharma"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <!-- Monthly Plan Badge -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#D9D9D9"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monthly plan active"
                                android:textColor="#000000"
                                android:textSize="12sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- WHITE CONTENT AREA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- PERSONAL INFO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFO"
                    android:textColor="#004533"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Name" android:textColor="#7A7A7A" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Priya Sharma" android:textColor="#000000" android:textSize="16sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Age" android:textColor="#7A7A7A" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="32 yrs" android:textColor="#000000" android:textSize="16sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Weight" android:textColor="#7A7A7A" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="55 kg" android:textColor="#000000" android:textSize="16sp"/>
                </LinearLayout>

                <!-- HEALTH CONDITIONS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEALTH CONDITIONS"
                    android:textColor="#004533"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <!-- Custom Chips Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardBackgroundColor="#D1F8D1" app:strokeWidth="0dp" app:cardElevation="0dp" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thyroid" android:textColor="#000000" android:textSize="14sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="6dp" android:paddingBottom="6dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardBackgroundColor="#D1F8D1" app:strokeWidth="0dp" app:cardElevation="0dp" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Type 2 Diabetes" android:textColor="#000000" android:textSize="14sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="6dp" android:paddingBottom="6dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="wrap_content" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardBackgroundColor="#D1F8D1" app:strokeWidth="0dp" app:cardElevation="0dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PCOS" android:textColor="#000000" android:textSize="14sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="6dp" android:paddingBottom="6dp"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- FOOD PREFERENCES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FOOD PREFERNCES"
                    android:textColor="#004533"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="95dp" android:layout_height="wrap_content" android:text="Diet" android:textColor="#7A7A7A" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vegetarian" android:textColor="#000000" android:textSize="16sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="95dp" android:layout_height="wrap_content" android:text="Spice level" android:textColor="#7A7A7A" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium" android:textColor="#000000" android:textSize="16sp"/>
                </LinearLayout>

                <!-- DELIVERY ADDRESS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELIVERY ADDRESS"
                    android:textColor="#004533"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EAF7E3"
                    app:strokeColor="#A3D6A3"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- House Icon Wrapper -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:strokeWidth="0dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="6dp"
                                android:src="@drawable/ic_home_address" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Home"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="14A Pali Hill,Bandra\nWest,Mumbai-400500"
                                android:textColor="#555555"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- EDIT PROFILE BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Edit Profile"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:backgroundTint="#006A4E"
                    app:cornerRadius="16dp"
                    android:layout_marginBottom="40dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR (Fixed to Bottom) -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_home" android:scaleType="fitCenter"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="13sp" android:maxLines="1" android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_plans" android:scaleType="fitCenter"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plans" android:textSize="13sp" android:maxLines="1" android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_progress" android:scaleType="fitCenter"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Progress" android:textSize="13sp" android:maxLines="1" android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_profile" android:scaleType="fitCenter"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="13sp" android:maxLines="1" android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>