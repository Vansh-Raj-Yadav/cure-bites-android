<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for "Choose your Healing Plan" screen.
    Structure:
    - Top toolbar: back arrow, logo, title, cart icon
    - ScrollView with 4 plan cards (Trial, Daily, Weekly, Monthly)
    - Bottom navigation bar with 4 tabs
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F0E8">

    <!-- ── TOP TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#F5F0E8">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:tint="#333333"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Spacer -->
        <View android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Logo + App name stacked in center -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CureBites"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Cart icon -->
        <ImageView
            android:id="@+id/ivCart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_cart"
            android:contentDescription="Cart"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:tint="#333333"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- ── PAGE TITLE ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose your Healing Plan"
        android:textColor="#2D4A1E"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp" />

    <!-- ── SCROLLABLE PLAN CARDS ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- ══════════════════════════════════
                 CARD 1 — Trial Pack (light green)
            ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/cardTrial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_plan_card_green"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <!-- Plan name -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trial pack"
                    android:textColor="#2D4A1E"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Plan subtitle -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 meal per day for 3 days"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <!-- Feature 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Customized to condition (e.g., diabetic-friendly, low-salt, gluten-free)"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Feature 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lets customer experience the taste &amp; quality before subscribing"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Get Started button -->
                <Button
                    android:id="@+id/btnTrial"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Get started"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2E7D32"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ══════════════════════════════════
                 CARD 2 — Daily Meal Plan (light green)
            ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/cardDaily"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_plan_card_green"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daily Meal Plan"
                    android:textColor="#2D4A1E"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All meals for a full day, delivered fresh"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Complete nutrition from breakfast to dinner"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Perfect for a one-day healthy reset"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnDaily"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Get started"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2E7D32"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ══════════════════════════════════
                 CARD 3 — Weekly Plan (light pink/red)
            ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/cardWeekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_plan_card_pink"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Weekly Plan"
                    android:textColor="#7B1A1A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All meals for 7 days"
                    android:textColor="#E57373"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle_red"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Balanced, hassle-free meals throughout the week"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle_red"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Stay consistent with your health goals"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Get started"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2E7D32"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ══════════════════════════════════
                 CARD 4 — Monthly Plan (light yellow/cream)
            ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/cardMonthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_plan_card_yellow"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monthly Plan"
                    android:textColor="#4A3000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All meals for 30 days"
                    android:textColor="#F9A825"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Long-term commitment to a healthy lifestyle"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="check"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Best value with fully planned daily nutrition"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Get started"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#2E7D32"
                    android:stateListAnimator="@null" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── BOTTOM NAVIGATION BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- Home tab -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Plans tab (active on this screen) -->
        <LinearLayout
            android:id="@+id/tabPlans"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plans"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Progress tab -->
        <LinearLayout
            android:id="@+id/tabProgress"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Profile tab -->
        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>