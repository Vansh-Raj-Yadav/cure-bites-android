<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="6dp">

        <!-- Main Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Green Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:gravity="center"
                    android:background="#009966">

                    <ImageView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:src="@drawable/app_logo"
                        android:scaleType="fitCenter"/>
                </LinearLayout>

                <!-- Bottom Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Dots -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="#D3D3D3"/>

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="1dp"/>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="#D3D3D3"/>

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="1dp"/>

                        <View
                            android:layout_width="32dp"
                            android:layout_height="8dp"
                            android:background="#F1E61A"/>
                    </LinearLayout>

                    <!-- Step -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Step 3 of 3"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#111111"
                        android:layout_marginTop="18dp"/>

                    <!-- Heading -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Our Story"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="18dp"/>

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cure Bites was born from a simple belief - food is the most powerful medicine. Founded by a team of nutritionists and health enthusiasts, we set out to make personalized healing nutrition accessible to everyone."
                        android:textSize="18sp"
                        android:textColor="#222222"
                        android:layout_marginTop="18dp"/>

                    <!-- Next Button -->
                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="Next"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#009966"
                        android:layout_marginTop="34dp"/>

                    <!-- Skip Button -->
                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="Skip"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:backgroundTint="#FFFFFF"
                        android:layout_marginTop="14dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>