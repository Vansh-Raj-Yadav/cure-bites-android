<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.curebites">


    <application
        android:allowBackup="true"
        android:forceDarkAllowed="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CureBites">

        <!-- LAUNCHER (ONLY ONE) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding & Login -->
        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".OnboardingActivity" android:exported="false" />
        <activity android:name=".Onboarding2Activity" android:exported="false" />
        <activity android:name=".Onboarding3Activity" android:exported="false" />
        <activity android:name=".TellUsActivity" android:exported="false" />
        <activity android:name=".HomeActivity" android:exported="false"/>

        <!-- Core App Screens -->
        <activity android:name=".HealingPlanActivity" android:exported="false" />
        <activity android:name=".MealPlanActivity" android:exported="false" />
        <activity android:name=".MealPlanTuesdayActivity" android:exported="false" />
        <activity android:name=".MealDetailsActivity" android:exported="false" />

        <!-- Features -->
        <activity android:name=".UploadReportActivity" android:exported="false" />
        <activity android:name=".NutritionistActivity"/>
        <activity android:name=".ChatNutritionistActivity" android:exported="false" />
        <activity android:name=".NotificationsActivity" android:exported="false" />
        <activity android:name=".ProfileActivity" android:exported="false" />
        <activity android:name=".MyprogressActivity" android:exported="false" />
        <activity android:name=".OrderHistoryActivity" android:exported="false" />

        <!-- Cart & Order Flow -->
        <activity android:name=".CartActivity" android:exported="false" />
        <activity android:name=".CheckoutActivity" android:exported="false" />
        <activity android:name=".OrderPlacedActivity" android:exported="false" />
        <activity android:name=".OrderTrackingActivity" android:exported="false" />

    </application>

</manifest>